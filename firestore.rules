rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidImportance(importance) {
      return importance == 'звичайна' || importance == 'важлива' || importance == 'критична';
    }

    function isValidEvent(data) {
      return data.title is string
        && data.title.size() > 0
        && data.date is string
        && data.importance is string
        && isValidImportance(data.importance)
        && data.userId is string
        && data.createdAt is number
        && data.updatedAt is number
        && (data.time == null || data.time is string)
        && (data.description == null || data.description is string);
    }

    match /events/{eventId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && isValidEvent(request.resource.data);
      
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && isValidEvent(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
